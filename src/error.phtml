<script>
    window.addEventListener("load", () => {
        for (const h3 of document.querySelectorAll(".array h3")) {
            h3.addEventListener('click', () => {
                const array = h3.closest('.array');
                const content = array.querySelector('.content');
                content?.classList.toggle('hide');
            });
        }
    });
</script>
