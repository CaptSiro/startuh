<?php /** @var Menu $this */

use components\core\Menu\Menu;

?><?php if ($this->item->hasChildren()): ?>
    <div
        class="<?= $this->level === 0 ? 'tool-bar' : 'dropdown' ?> <?= $this->getCssClass() ?> <?= !$this->isInset ? 'no-inset' : '' ?>"
        style="--menu-level: <?= $this->level ?>"
    >
        <?php foreach ($this->item->getChildren() as $child): ?>
            <?php $subMenu = $this->createSubMenu($child)->setTemplate($this->template) ?>
            <?php $mit = $this->level === 0 ? 'menu-item-top' : '' ?>
            <div class="menu-item <?= $subMenu->getStateClasses() ?> <?= $mit ?>">
                <?= $subMenu->createItem() ?>
                <?= $subMenu ?>
            </div>
        <?php endforeach; ?>
    </div>
<?php endif; ?>