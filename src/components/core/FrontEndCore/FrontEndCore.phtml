use core\sideloader\SideLoader;

?><?php if (SideLoader::getInstance()->isInitialized()): ?>
    <script
        <?= SideLoader::getInstance()
            ->createSourceAttribute(
                Javascript::FILE_EXTENSION,
                $this->getPublicSources('js', '*.js')
            ) ?>
    ></script>

    <link
        rel="stylesheet"
        <?= SideLoader::getInstance()
            ->createSourceAttribute(
                Css::FILE_EXTENSION,
                $this->getPublicSources('css', '*.css'),
                'href'
            ) ?>
    >
<?php endif; ?>
