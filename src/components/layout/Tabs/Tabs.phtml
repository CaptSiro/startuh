<?php /** @var Tabs $this */

use components\layout\Tabs\Tabs;
use core\sideloader\importers\Css\Css;
use core\sideloader\importers\Javascript\Javascript;

?>
<?php Css::import($this->getResource("tabs.css")); ?>
<?php Javascript::import($this->getResource('tabs.js')); ?>
<?php $this->updateSelected(); ?>
<div class="tabs" x-init="tabs">
    <div class="labels">
        <?php $i = 0; foreach (array_keys($this->tabs) as $label): ?>
            <div
                class="label <?= $this->isSelected($label, $i) ? 'selected' : ''?>"
                data-label="<?= $label // todo escape ?>"
            >
                <?= $label ?>
            </div>
            <?php $i++; ?>
        <?php endforeach; ?>
    </div>

    <?php $i = 0; foreach ($this->tabs as $label => $view): ?>
        <div
            class="tabs__wrapper <?= $this->isSelected($label, $i) ? 'selected' : '' ?>"
            data-label="<?= $label // todo escape ?>"
        >
            <?= $view->render() ?>
        </div>
    <?php $i++; endforeach; ?>
</div>
